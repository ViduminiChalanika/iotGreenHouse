# MongoDB Atlas (same as before)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=greenhouse
MONGODB_COLLECTION=readings

# Shared secret: must match API_KEY in ESP32 include/secrets.h
API_KEY=change-this-to-a-long-random-string

# Local dev port (hosting platforms set PORT automatically)
PORT=3000
