# HiveMQ Cloud (or any MQTT broker): use mqtts:// for TLS, e.g. port 8883
MQTT_URL=mqtts://YOUR_CLUSTER.hivemq.cloud:8883
MQTT_USER=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# Must match ESP32 MQTT_TOPIC_PUBLISH
MQTT_TOPIC=greenhouse/telemetry

